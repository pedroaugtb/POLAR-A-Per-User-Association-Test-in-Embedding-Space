{
  "input_format": "json_tweets",
  "input_json": "data/bot_human_data.json",
  "out_dir": "outputs/bot_human_paper",
  "base_model": "bert-base-uncased",
  "usr_prefix": "usr",
  "max_len": 128,
  "epochs": 4,
  "batch_size": 128,
  "users_per_batch": 128,
  "lr": 5e-05,
  "mlm_prob": 0.15,
  "p_user_mask": 0.3,
  "seed": 42,
  "num_workers": 4,
  "tokenize_chunk": 4096,
  "min_posts_per_user": 2,
  "export_kv": false,
  "grad_clip": 1.0,
  "grad_accum_steps": 1,
  "warmup_ratio": 0.03,
  "per_user_cap": 200,
  "freeze_epochs": 1,
  "max_tweets_per_user": 200,
  "align_use_hidden": false,
  "align_lambda": 0.2,
  "con_weight": 0.0,
  "con_temperature": 0.07,
  "soft_prompt_len": 0
}
