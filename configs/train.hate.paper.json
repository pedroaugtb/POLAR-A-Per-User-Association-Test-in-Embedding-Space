{
  "input_format": "txt_csv",
  "txt_dir": "data/hate/all_files",
  "annotations_csv": "data/hate/annotations_metadata.csv",
  "out_dir": "outputs/hate_paper",
  "base_model": "bert-base-uncased",
  "usr_prefix": "usr",
  "max_len": 128,
  "epochs": 4,
  "batch_size": 128,
  "users_per_batch": 128,
  "lr": 5e-05,
  "mlm_prob": 0.15,
  "p_user_mask": 0.3,
  "seed": 42,
  "num_workers": 4,
  "tokenize_chunk": 4096,
  "min_posts_per_user": 2,
  "export_kv": false,
  "grad_clip": 1.0,
  "grad_accum_steps": 1,
  "warmup_ratio": 0.03,
  "per_user_cap": 50,
  "freeze_epochs": 1,
  "max_tweets_per_user": null,
  "align_use_hidden": false,
  "align_lambda": 0.2,
  "con_weight": 0.0,
  "con_temperature": 0.07,
  "soft_prompt_len": 0
}
